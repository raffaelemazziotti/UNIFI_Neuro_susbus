=Neurogenesis #Neurogenesis is the generation of neurons.
~Myelination
}

::plast_which_developmental::
Which developmental process involves programmed cell death?
{
~Neurulation
~Synaptogenesis
=Apoptosis #Apoptosis eliminates excess or improperly connected cells.
~Myelination
}

::plast_which_developmental::
Which developmental process improves conduction speed along axons?
{
~Gliogenesis
=Myelination #Myelination increases conduction velocity.
~Neurogenesis
~Synaptogenesis
}

::plast_gene_specification::
